///|
pub(all) enum MormType {
  Null
  Bit(Bool)
  TinyInt(Int)
  SmallInt(Int)
  Integer(Int)
  BigInt(Int)
  Float(Float)
  Double(Double)
  Numeric(String)
  Decimal(String)
  Char(String)
  VarChar(String)
  LongVarChar(String)
  Date(@time.PlainDate)
  Time(@time.PlainTime)
  Timestamp(@time.PlainDateTime)
  Binary(Bytes)
  VarBinary(Bytes)
  LongVarBinary(Bytes)
  Other(String)
  Distinct(String)
  Struct(String)
  Array(String)
  Blob(Bytes)
  Clob(String)
  Ref(String)
  DataLink(String)
  Boolean(Bool)
  RowId(String)
  NChar(String)
  NVarChar(String)
  LongNVarChar(String)
  NClob(String)
  SqlXml(String)
  RefCursor(String)
  TimeWithTimeZone(@time.PlainTime, @time.Zone)
  TimestampWithTimeZone(@time.ZonedDateTime)
} derive(Show)
