///|
fn must_ok(step : String, ok : Bool) -> Unit {
  if !ok {
    println("step failed: \{step}")
    panic()
  }
}

///|
async fn main {
  let engine = @sqlite3.SQLiteEngine::open(":memory:")

  // Use codegen table schema.
  must_ok(
    "migrate user table",
    engine.migrate_table(User::table().to_json()).ok,
  )

  // Mapper implementation is generated by mormgen.
  let mapper = UserMapperImpl::new(engine)

  // C: save
  let created = mapper.save(User::{
    id: 1,
    email: "alice@example.com",
    active: 1,
  })
  must_ok("save user", created)
  println("crud_codegen: created=true")

  // R: find by id
  if mapper.find_user_by_id(1) is Some(user) {
    println("crud_codegen: read=\{user.to_json().stringify()}")
  } else {
    println("crud_codegen: read=null")
  }

  // U: update
  let updated = mapper.update(User::{
    id: 1,
    email: "alice@example.com",
    active: 0,
  })
  must_ok("update user", updated)
  println("crud_codegen: updated=true")

  if mapper.find_user_by_id(1) is Some(user) {
    println("crud_codegen: after_update=\{user.to_json().stringify()}")
  }

  // D: delete
  let deleted = mapper.delete(User::{
    id: 1,
    email: "alice@example.com",
    active: 0,
  })
  must_ok("delete user", deleted)
  println("crud_codegen: deleted=true")

  let final_user = mapper.find_user_by_id(1)
  println("crud_codegen: final=\{final_user.to_json().stringify()}")

  engine.close()
}
